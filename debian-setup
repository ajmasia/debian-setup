#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION="$(cat "${SCRIPT_DIR}/VERSION")"

# Source libraries (order matters)
source "${SCRIPT_DIR}/src/lib/colors.sh"
source "${SCRIPT_DIR}/src/lib/xdg.sh"
source "${SCRIPT_DIR}/src/lib/log.sh"
source "${SCRIPT_DIR}/src/lib/system.sh"
source "${SCRIPT_DIR}/src/lib/gum.sh"
source "${SCRIPT_DIR}/src/lib/ui.sh"

# Source menu and modules
source "${SCRIPT_DIR}/src/menu.sh"
source "${SCRIPT_DIR}/src/modules/health.sh"
source "${SCRIPT_DIR}/src/modules/system/sudoers.sh"
source "${SCRIPT_DIR}/src/modules/system/pwfeedback.sh"
source "${SCRIPT_DIR}/src/modules/system/editor.sh"
source "${SCRIPT_DIR}/src/modules/system/zram.sh"
source "${SCRIPT_DIR}/src/modules/system/main.sh"
source "${SCRIPT_DIR}/src/modules/settings/logs.sh"
source "${SCRIPT_DIR}/src/modules/settings/main.sh"

show_version() {
    printf "debian-setup %s\n" "$VERSION"
}

show_help() {
    printf "debian-setup %s\n\n" "$VERSION"
    printf "Usage: debian-setup [options]\n\n"
    printf "Options:\n"
    printf "  -v, --version    Show version\n"
    printf "  -h, --help       Show this help message\n"
}

main() {
    xdg::init

    case "${1:-}" in
        -v|--version)
            show_version
            return 0
            ;;
        -h|--help)
            show_help
            return 0
            ;;
    esac

    gum::check

    ui::clear
    log::break
    ui::header "$VERSION"
    ui::session_info
    system::log_status

    menu::main
}

main "$@"
