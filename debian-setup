#!/usr/bin/env bash
set -euo pipefail

trap 'printf "\n"; exit 130' INT

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION="$(cat "${SCRIPT_DIR}/VERSION")"

# Source libraries (order matters)
source "${SCRIPT_DIR}/src/lib/colors.sh"
source "${SCRIPT_DIR}/src/lib/xdg.sh"
source "${SCRIPT_DIR}/src/lib/log.sh"
source "${SCRIPT_DIR}/src/lib/system.sh"
source "${SCRIPT_DIR}/src/lib/gum.sh"
source "${SCRIPT_DIR}/src/lib/ui.sh"
source "${SCRIPT_DIR}/src/lib/apt.sh"

# Source menu and modules
source "${SCRIPT_DIR}/src/menu.sh"
source "${SCRIPT_DIR}/src/modules/health.sh"
source "${SCRIPT_DIR}/src/modules/system/sudoers.sh"
source "${SCRIPT_DIR}/src/modules/system/pwfeedback.sh"
source "${SCRIPT_DIR}/src/modules/system/editor.sh"
source "${SCRIPT_DIR}/src/modules/system/zram.sh"
source "${SCRIPT_DIR}/src/modules/system/kernel.sh"
source "${SCRIPT_DIR}/src/modules/system/slimbook.sh"
source "${SCRIPT_DIR}/src/modules/system/main.sh"
source "${SCRIPT_DIR}/src/modules/packages/apt.sh"
source "${SCRIPT_DIR}/src/modules/packages/flatpak.sh"
source "${SCRIPT_DIR}/src/modules/packages/nix.sh"
source "${SCRIPT_DIR}/src/modules/packages/main.sh"
source "${SCRIPT_DIR}/src/modules/ssh/server.sh"
source "${SCRIPT_DIR}/src/modules/ssh/access.sh"
source "${SCRIPT_DIR}/src/modules/ssh/keys.sh"
source "${SCRIPT_DIR}/src/modules/ssh/config.sh"
source "${SCRIPT_DIR}/src/modules/ssh/signing.sh"
source "${SCRIPT_DIR}/src/modules/ssh/main.sh"
source "${SCRIPT_DIR}/src/modules/devtools/build.sh"
source "${SCRIPT_DIR}/src/modules/devtools/node.sh"
source "${SCRIPT_DIR}/src/modules/devtools/python.sh"
source "${SCRIPT_DIR}/src/modules/devtools/rust.sh"
source "${SCRIPT_DIR}/src/modules/devtools/go.sh"
source "${SCRIPT_DIR}/src/modules/devtools/main.sh"
source "${SCRIPT_DIR}/src/modules/software/utils.sh"
source "${SCRIPT_DIR}/src/modules/software/media.sh"
source "${SCRIPT_DIR}/src/modules/software/vscode.sh"
source "${SCRIPT_DIR}/src/modules/software/neovim.sh"
source "${SCRIPT_DIR}/src/modules/software/editors.sh"
source "${SCRIPT_DIR}/src/modules/software/alacritty.sh"
source "${SCRIPT_DIR}/src/modules/software/kitty.sh"
source "${SCRIPT_DIR}/src/modules/software/ptyxis.sh"
source "${SCRIPT_DIR}/src/modules/software/terminals.sh"
source "${SCRIPT_DIR}/src/modules/software/brave.sh"
source "${SCRIPT_DIR}/src/modules/software/librewolf.sh"
source "${SCRIPT_DIR}/src/modules/software/mullvad.sh"
source "${SCRIPT_DIR}/src/modules/software/chromium.sh"
source "${SCRIPT_DIR}/src/modules/software/browsers.sh"
source "${SCRIPT_DIR}/src/modules/software/main.sh"
source "${SCRIPT_DIR}/src/modules/settings/logs.sh"
source "${SCRIPT_DIR}/src/modules/settings/main.sh"

show_version() {
    printf "debian-setup %s\n" "$VERSION"
}

show_help() {
    printf "debian-setup %s\n\n" "$VERSION"
    printf "Usage: debian-setup [options]\n\n"
    printf "Options:\n"
    printf "  -v, --version    Show version\n"
    printf "  -h, --help       Show this help message\n"
}

main() {
    xdg::init

    case "${1:-}" in
        -v|--version)
            show_version
            return 0
            ;;
        -h|--help)
            show_help
            return 0
            ;;
    esac

    gum::check

    ui::clear
    log::break
    ui::header "$VERSION"
    ui::session_info

    menu::main
}

main "$@"
