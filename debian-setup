show_version() {
    printf "debian-setup %s\n" "$VERSION"
}

show_help() {
    printf "debian-setup %s\n\n" "$VERSION"
    printf "Usage: debian-setup [options]\n\n"
    printf "Options:\n"
    printf "  -v, --version    Show version\n"
    printf "  -h, --help       Show this help message\n"
}

main() {
    xdg::init

    case "${1:-}" in
        -v|--version)
            show_version
            return 0
            ;;
        -h|--help)
            show_help
            return 0
            ;;
    esac

    gum::check

    ui::clear
    log::break
    ui::header "$VERSION"
    ui::session_info

    menu::main
}

main "$@"
